#usda 1.0
(
    customLayerData = {
        string creator = "MuJoCo USD Converter v0.1.0"
    }
    defaultPrim = "magpie_gripper"
    kilogramsPerUnit = 1
    metersPerUnit = 1
    upAxis = "Z"
)

def Xform "magpie_gripper"
{
    def Scope "Physics"
    {
        def Material "PhysicsMaterial" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI", "MjcMaterialAPI"]
        )
        {
            float newton:rollingFriction = 0.0001
            float newton:torsionalFriction = 0.005
            float physics:dynamicFriction = 1
        }

        def Material "PhysicsMaterial_1" (
            prepend apiSchemas = ["PhysicsMaterialAPI", "NewtonMaterialAPI", "MjcMaterialAPI"]
        )
        {
            float newton:rollingFriction = 0.0001
            float newton:torsionalFriction = 0.005
            float physics:dynamicFriction = 0.6
        }

        def MjcActuator "left_finger_actuator"
        {
            uniform double[] mjc:biasPrm = [0, -10, 0, 0, 0, 0, 0, 0, 0, 0]
            uniform token mjc:biasType = "affine"
            uniform double mjc:ctrlRange:max = 2.7
            uniform double mjc:ctrlRange:min = -0.035
            uniform double[] mjc:gainPrm = [10, 0, 0, 0, 0, 0, 0, 0, 0, 0]
            rel mjc:target = </magpie_gripper/Geometry/base_bot/base_top/left_crank/left_hinge_1>
        }

        def MjcActuator "right_finger_actuator"
        {
            uniform double[] mjc:biasPrm = [0, -10, 0, 0, 0, 0, 0, 0, 0, 0]
            uniform token mjc:biasType = "affine"
            uniform double mjc:ctrlRange:max = 0.035
            uniform double mjc:ctrlRange:min = -2.7
            uniform double[] mjc:gainPrm = [10, 0, 0, 0, 0, 0, 0, 0, 0, 0]
            rel mjc:target = </magpie_gripper/Geometry/base_bot/base_top/right_crank/right_hinge_1>
        }

        def PhysicsSphericalJoint "left_4bar_close" (
            prepend apiSchemas = ["MjcEqualityConnectAPI"]
        )
        {
            uniform token physics:axis = "X"
            rel physics:body0 = </magpie_gripper/Geometry/base_bot/base_top>
            rel physics:body1 = </magpie_gripper/Geometry/base_bot/base_top/left_crank/left_finger_combined/left_rocker>
            uniform bool physics:excludeFromArticulation = 1
            point3f physics:localPos0 = (-0.00075, 0.06, 0.065)
            point3f physics:localPos1 = (0.006, -0.039824, -0.020954)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }

        def PhysicsSphericalJoint "right_4bar_close" (
            prepend apiSchemas = ["MjcEqualityConnectAPI"]
        )
        {
            uniform token physics:axis = "X"
            rel physics:body0 = </magpie_gripper/Geometry/base_bot/base_top>
            rel physics:body1 = </magpie_gripper/Geometry/base_bot/base_top/right_crank/right_finger_combined/right_rocker>
            uniform bool physics:excludeFromArticulation = 1
            point3f physics:localPos0 = (-0.00075, -0.06, 0.065)
            point3f physics:localPos1 = (0.006, 0.039824, -0.020954)
            quatf physics:localRot0 = (1, 0, 0, 0)
            quatf physics:localRot1 = (1, 0, 0, 0)
        }
    }

    def "Geometry"
    {
