# ==============================
# Isaac Sim 4.5.0 + IsaacLab + teleimager on humanoid_sim_base.
# Single-stage: base image already has ROS + Python + torch + unitree_sdk2py.
#
# Isaac Sim version note: pinned to 4.5.0.0, the latest release with Python 3.10
# wheels on pypi.nvidia.com. Isaac Sim 5.x requires Python 3.11 and 6.x requires
# 3.12 — both incompatible with the apt-ROS Python 3.10 base. IsaacLab is pinned
# correspondingly to a tag that does not require `wp.transform_compose`
# (introduced in Isaac Sim 5.1+'s bundled omni.warp.core).
# ==============================
FROM humanoid_sim_base:latest

ENV OMNI_KIT_ACCEPT_EULA=yes
ENV OMNI_KIT_ALLOW_ROOT=1

ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}

# Install Isaac Sim 4.5.0.0. Multi-GB, rarely changes — keep early in layer order.
# Order matters: Isaac Sim pulls its own torch, which we override below.
# UV_HTTP_TIMEOUT raised from the 30s default because the NVIDIA PyPI index
# serves multi-hundred-MB wheels that can stall past default.
RUN UV_HTTP_TIMEOUT=600 uv pip install --system --no-cache \
        "isaacsim[all,extscache]==4.5.0.0" \
        --extra-index-url https://pypi.nvidia.com

# Downgrade pip/setuptools for IsaacLab compatibility. IsaacLab's install script
# breaks on newer versions. uv does not replace pip entirely — IsaacLab's
# ./isaaclab.sh invokes pip internally, so the pinned pip is still needed.
RUN uv pip install --system "pip==23" "setuptools==65" flatdict

# Install torch cu130 up front so IsaacLab's install step below has a torch
# present when it resolves its `torch==2.5.1` pin (it will still downgrade to
# the PyPI cu124 wheel — we re-install cu130 after IsaacLab runs).
RUN UV_HTTP_TIMEOUT=600 uv pip install --system --no-cache \
        torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu130

# Install IsaacLab pinned to a tag compatible with Isaac Sim 4.5.0.
# ISAACLAB_REF can be overridden at build time if v2.0.2 is not the right tag.
# Pin cmake<4 to work around egl_probe's outdated CMakeLists.txt (cmake 4.0
# rejects cmake_minimum_required < 3.5).
# TERM needs a real terminfo entry because isaaclab.sh uses tput for colored
# output; Docker build leaves TERM unset, which makes tput emit
# "'ansi+tabs': unknown terminal type" and fail the step.
ARG ISAACLAB_REF=v2.0.2
RUN TERM=xterm-256color uv pip install --system "cmake<4" && \
    git clone --branch ${ISAACLAB_REF} --depth 1 \
        https://github.com/isaac-sim/IsaacLab /home/code/IsaacLab && \
    cd /home/code/IsaacLab && TERM=xterm-256color ./isaaclab.sh --install

# Install CL_isaaclab_sim requirements only. The full tree is bind-mounted at
# runtime (docker-compose.yml -> /home/code/CL_isaaclab_sim), so baking the
# source in would be shadowed. Copy just requirements.txt so edits don't
# invalidate this layer.
COPY CL_isaaclab_sim/requirements.txt /tmp/cl_requirements.txt
RUN uv pip install --system -r /tmp/cl_requirements.txt && rm /tmp/cl_requirements.txt

# Re-install torch cu130 AFTER IsaacLab. IsaacLab's isaaclab_*/setup.py pin
# `torch==2.5.1`, whose PyPI wheel is cu124 and ships no sm_120 (Blackwell)
# kernels — so at runtime an RTX 50-series GPU fails with "no kernel image is
# available for execution on the device". Force-reinstalling the cu130 wheel
# here provides sm_120 support. pip will warn that IsaacLab asked for 2.5.1;
# ignore — the IsaacLab APIs we exercise are compatible with torch 2.11+cu130.
RUN UV_HTTP_TIMEOUT=600 uv pip install --system --no-cache --force-reinstall \
        torch torchvision torchaudio \
        --index-url https://download.pytorch.org/whl/cu130

# Register the cu130 CUDA shared library dir with ldconfig. The torch cu130
# wheel's own `torch/lib` is empty — CUDA libs live under the `nvidia-cu13`
# namespace package at `.../nvidia/cu13/lib`. `import torch` loads its core
# `.so` files via `ctypes.CDLL` with full paths, so normal CUDA ops work even
# without the dir on the loader path — but torch's C++ NVRTC JIT calls plain
# `dlopen("libnvrtc-builtins.so.13.0", ...)` with the bare soname, which goes
# through the system loader and fails ("failed to open libnvrtc-builtins.so.13.0")
# unless the dir is in ldconfig's cache. Add it.
RUN echo '/usr/local/lib/python3.10/dist-packages/nvidia/cu13/lib' \
        > /etc/ld.so.conf.d/nvidia-cu13.conf && \
    ldconfig

# Force-reinstall numpy to fix any version mismatch between compiled C extensions
# and Python code caused by conflicting pip installs (torch cu130 vs IsaacLab).
# Pin to 1.x: Isaac Sim 4.5.0's bundled numpy under omni.kit.pip_archive's
# pip_prebundle does `from numpy.lib.stride_tricks import broadcast_to`, which
# numpy 2.0 removed from that submodule. Must run AFTER the torch cu130 pin
# above, because torch 2.11+cu130 transitively pulls numpy 2.x.
RUN uv pip install --system --force-reinstall "numpy<2"

# Assets live on the host and are mounted at runtime via docker-compose (not baked in).

# NOTE: deliberately NOT prepending isaacsim.ros2.bridge/humble/lib to
# LD_LIBRARY_PATH. That bundled dir contains an older librmw_cyclonedds_cpp.so
# that references `shm_set_data_state` (missing from every libddsc 0.10.5 in
# the stack). When it was on LD_LIBRARY_PATH, rcl's dlopen resolved the soname
# against the bundled (broken) rmw, causing "undefined symbol: shm_set_data_state"
# and blocking cl_load_rs.

WORKDIR /home/code

CMD ["/bin/bash"]
