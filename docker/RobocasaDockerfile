# ==============================
# MuJoCo 3.3.1 sim on hams_base.
# Single-stage: base image already has ROS + Python + torch + unitree_sdk2py.
# Source tree bind-mounted at runtime (docker-compose.yml -> /home/code/h1_robocasa).
# Robocasa (kitchen scenes) is installed from git; pins MuJoCo to 3.3.1.
# ==============================
FROM hams_base:latest

ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}

# Default backend baked into the image. Operational default is GLFW: docker-compose
# exports MUJOCO_GL=${MUJOCO_GL:-glfw} and launch_mujoco.sh forces glfw unless
# --headless (in which case it switches to egl for offscreen GPU rendering).
ENV MUJOCO_GL=egl

# MuJoCo runtime graphics libs (EGL + OSMesa for headless rendering).
RUN apt-get update && apt-get install -y --no-install-recommends \
        libegl1-mesa libosmesa6 \
    && rm -rf /var/lib/apt/lists/*

# MuJoCo Python binding + Pillow for image encoding.
# NOTE: pinned to 3.3.1 to match Robocasa's hard pin (see below). Earlier
# this image used 3.6.0; downgraded so that `pip install robocasa` doesn't
# silently swap the version mid-install.
RUN uv pip install --system --no-cache \
        "mujoco==3.3.1" \
        "numpy>=2.2.6" \
        "Pillow>=10.0"

# Robocasa kitchen scenes (used by `h12_mujoco.py --scene kitchen`).
# Both packages are git-only — robocasa is not on PyPI, and Robocasa pins
# the *master* branch of robosuite (per robocasa.ai install docs). robosuite
# is required because Robocasa's KitchenArena inherits from
# robosuite.models.arenas.Arena.
#
# Side effect: lerobot (a Robocasa transitive) pins torch==2.7.1, which
# downgrades the cu130 torch in the base image to a CPU/cu121 build for
# this image only. Acceptable for the mujoco sim container; the Isaac
# container retains cu130 because it builds from base independently.
RUN git clone --depth 1 https://github.com/ARISE-Initiative/robosuite /opt/robosuite && \
    uv pip install --system --no-cache -e /opt/robosuite

RUN git clone --depth 1 https://github.com/robocasa/robocasa /opt/robocasa && \
    uv pip install --system --no-cache -e /opt/robocasa

# Robocasa & robosuite both warn on first import about a missing private
# macro file. Run their setup scripts once at build time to suppress the
# warnings and create the macros file in-image.
RUN python /opt/robosuite/robosuite/scripts/setup_macros.py && \
    python /opt/robocasa/robocasa/scripts/setup_macros.py

# Optional robosuite/robocasa deps that print "WARNING: not installed" on
# every import otherwise:
#   - robosuite_models: extra robot meshes (git-only — not on PyPI).
#   - mink: whole-body IK; robosuite hard-codes the 0.0.5 pin in its warning.
#   - mimicgen: demonstration-generation environments (git-only).
# We don't *use* any of these — installation is purely to silence the
# import-time warnings.
RUN git clone --depth 1 https://github.com/ARISE-Initiative/robosuite_models /opt/robosuite_models && \
    uv pip install --system --no-cache -e /opt/robosuite_models && \
    git clone --depth 1 https://github.com/NVlabs/mimicgen /opt/mimicgen && \
    uv pip install --system --no-cache -e /opt/mimicgen && \
    uv pip install --system --no-cache --no-deps "mink==0.0.5"

# Robocasa's textures, fixtures, and objects (~10 GB) — required for any
# `--scene kitchen` run; KitchenArena fails immediately without them.
# Baked into the image so `docker compose build` produces a ready-to-run
# container. Tradeoff: image is ~10 GB larger; pushes/pulls take longer.
# To skip and download manually instead, comment out this RUN step and
# run inside the container:
#     echo y | python -m robocasa.scripts.download_kitchen_assets --type all
#
# `echo y` answers the script's interactive ~10 Gb confirmation prompt
# (the script has no --no-input/--yes flag). Per-folder overwrite prompts
# are suppressed because every entry in DOWNLOAD_ASSET_REGISTRY sets
# check_folder_exists=False.
RUN echo y | python -m robocasa.scripts.download_kitchen_assets --type all

WORKDIR /home/code/h1_robocasa

CMD ["/bin/bash"]

# -----------------------------------------------------------------------------
# msgs_ws toolchain — minimal colcon + ament + rosidl_default_generators so
# launch_mujoco.sh can build the IDL-only workspace at every container start
# (magpie_msgs + custom_ros_messages, both ament_cmake interface packages).
# Appended at the end intentionally so iterating on this layer does not bust
# the heavy mujoco/robocasa/asset layers above.
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3-colcon-common-extensions \
        ros-humble-ament-cmake \
        ros-humble-ament-cmake-auto \
        ros-humble-ament-cmake-python \
        ros-humble-rosidl-default-generators \
    && rm -rf /var/lib/apt/lists/*

# Bind-mount target for ../core_ws/src/{magpie_msgs,custom_ros_messages}.
RUN mkdir -p /home/code/msgs_ws/src

# -----------------------------------------------------------------------------
# Livox-SDK2 — required by livox_ros_driver2's C++ library (and therefore by
# its message generation, since the package builds them together). Identical
# recipe to RosDockerfile so both containers' livox builds resolve the same
# system library. Appended at the end so iterating on this layer does not bust
# the heavy mujoco/robocasa/asset layers above.
# -----------------------------------------------------------------------------
RUN git clone --depth 1 https://github.com/Livox-SDK/Livox-SDK2.git /tmp/Livox-SDK2 && \
    cd /tmp/Livox-SDK2 && mkdir build && cd build && \
    cmake .. -DCMAKE_POLICY_VERSION_MINIMUM=3.5 && make -j"$(nproc)" && make install && \
    ldconfig && \
    rm -rf /tmp/Livox-SDK2

# -----------------------------------------------------------------------------
# apt deps required by livox_ros_driver2's C++ build (see
# core_ws/src/livox_ros_driver2/package_ROS2.xml).
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        libpcl-dev libapr1-dev \
        ros-humble-pcl-conversions ros-humble-pcl-ros \
        ros-humble-rclcpp-components ros-humble-rcl-interfaces \
        ros-humble-rosbag2 \
        ros-humble-sensor-msgs ros-humble-std-msgs \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# livox_ros_driver2 baked into the image so the mujoco bridge can publish
# proper livox_ros_driver2/msg/CustomMsg on /livox/lidar. Bind-mount would
# collide with the ros container's bind-mount of core_ws/src (build.sh writes
# to its source tree: package_ROS2.xml -> package.xml and launch_ROS2/ ->
# launch/), so we COPY a snapshot in here and build via the upstream-supported
# build.sh entry point. build.sh rm -rf's ../../build and ../../install before
# building, so /opt/livox_ws/src must contain only this one package.
# -----------------------------------------------------------------------------
COPY core_ws/src/livox_ros_driver2 /opt/livox_ws/src/livox_ros_driver2
# Do not rm -rf /opt/livox_ws/build afterwards — build.sh uses
# --symlink-install, which makes install/ contain symlinks pointing back into
# build/ for generated message modules and local_setup.bash. Wiping build/
# breaks those symlinks and the Python `from livox_ros_driver2.msg import
# CustomMsg` fails at runtime. The build dir is small (~20 MB) so just leave it.
RUN bash -c "source /opt/ros/humble/setup.bash && \
             cd /opt/livox_ws/src/livox_ros_driver2 && \
             ./build.sh humble"
