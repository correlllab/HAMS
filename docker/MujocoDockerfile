# ==============================
# MuJoCo 3.6.0 sim on humanoid_sim_base.
# Single-stage: base image already has ROS + Python + torch + unitree_sdk2py.
# Source tree bind-mounted at runtime (docker-compose.yml -> /home/code/h1_mujoco).
# ==============================
FROM humanoid_sim_base:latest

ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}

# Default backend baked into the image. Operational default is GLFW: docker-compose
# exports MUJOCO_GL=${MUJOCO_GL:-glfw} and launch_mujoco.sh forces glfw unless
# --headless (in which case it switches to egl for offscreen GPU rendering).
ENV MUJOCO_GL=egl

# MuJoCo runtime graphics libs (EGL + OSMesa for headless rendering).
RUN apt-get update && apt-get install -y --no-install-recommends \
        libegl1-mesa libosmesa6 \
    && rm -rf /var/lib/apt/lists/*

# MuJoCo Python binding + Pillow for image encoding.
RUN uv pip install --system --no-cache \
        "mujoco==3.6.0" \
        "numpy>=2.2.6" \
        "Pillow>=10.0"

WORKDIR /home/code/h1_mujoco

CMD ["/bin/bash"]
