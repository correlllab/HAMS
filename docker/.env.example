# Copy this file to .env and fill in real values:
#   cp docker/.env.example docker/.env
#
# docker compose auto-loads docker/.env (the project dir of docker-compose.yml),
# and docker_run.sh also sources it so the values are available to the script.

# Gemini API key for the vision pipeline's gemini backbone + h12_skills.
GEMINI_API_KEY=your-gemini-api-key-here

# ROS 2 DDS domain. Sims publish on domain 1; domain 0 is reserved for the real robot.
ROS_DOMAIN_ID=1
