# ==============================
# ROS 2 Humble workspace image on hams_base.
#
# Inherits base's CUDA, Python 3.10, ROS 2 Humble, CycloneDDS 0.10.x (from
# source), uv, unitree_sdk2_python, torch cu130, and pin/pink/mink, then
# layers on the ROS workspace extras: colcon, rviz2, apt pinocchio (for C++
# packages in core_ws), FAST_LIO / livox_ros_driver2 deps, and the
# vision_pipeline ML stack. numpy is pinned to <2 at the end for
# scipy/pinocchio ABI compatibility.
#
# Cross-container DDS: base installs CycloneDDS 0.10.x from source with
# ros-humble-rmw-cyclonedds-cpp on top. All containers (sim + ROS) share this
# stack and interop on ROS_DOMAIN_ID=1.
#
# Layer order is most-stable → least-stable so iterating on pip pins does not
# bust the apt and Livox-SDK2 cmake layers above. Within pip, the controller /
# IK stack comes before the volatile vision ML stack for the same reason.
# ==============================
FROM hams_base:latest

ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}

# -----------------------------------------------------------------------------
# 1. apt: build tooling, system Python C-extensions, ROS workspace deps
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        # build / packaging tooling
        pkg-config \
        python3-colcon-common-extensions \
        python3-rosdep \
        python3-vcstool \
        # apt-built Python deps with C extensions (must match system ABIs)
        python3-numpy python3-scipy python3-yaml python3-transforms3d \
        # C++ libs core_ws packages link against
        libpcl-dev libeigen3-dev libyaml-cpp-dev libopencv-dev \
        # ament / rosidl build system
        ros-humble-ament-cmake \
        ros-humble-ament-cmake-auto \
        ros-humble-ament-cmake-python \
        ros-humble-ament-lint-auto \
        ros-humble-rosidl-default-generators \
        # Foxy-era DDS IDL generator. Not pulled in by ros-base or
        # rosidl-default-generators on Humble, but unitree_ros2 packages
        # (unitree_api/go/hg) still find_package(rosidl_generator_dds_idl REQUIRED).
        ros-humble-rosidl-generator-dds-idl \
        # ROS message types referenced across the workspace
        ros-humble-image-transport \
        ros-humble-vision-msgs \
        ros-humble-nav-msgs \
        ros-humble-std-msgs \
        ros-humble-std-srvs \
        ros-humble-visualization-msgs \
        # robot description + launch
        ros-humble-xacro \
        ros-humble-robot-state-publisher \
        ros-humble-joint-state-publisher \
        ros-humble-launch-ros \
        ros-humble-launch-xml \
        # PCL / TF integration
        ros-humble-pcl-ros \
        ros-humble-pcl-conversions \
        ros-humble-tf2-eigen \
        ros-humble-tf2-tools \
        # rclcpp + visualization
        ros-humble-rclcpp \
        ros-humble-rclcpp-components \
        ros-humble-rviz2 \
        # apt pinocchio (C++ symbols) for core_ws packages — coexists with base's pip `pin`
        ros-humble-pinocchio \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# 2. Livox-SDK2 from source — required by livox_ros_driver2 in core_ws.
#    Placed before the Python layers so iterating on pip pins does not bust
#    the cmake build. CMAKE_POLICY_VERSION_MINIMUM works around upstream's
#    outdated cmake_minimum_required.
# -----------------------------------------------------------------------------
RUN git clone --depth 1 https://github.com/Livox-SDK/Livox-SDK2.git /tmp/Livox-SDK2 && \
    cd /tmp/Livox-SDK2 && mkdir build && cd build && \
    cmake .. -DCMAKE_POLICY_VERSION_MINIMUM=3.5 && make -j"$(nproc)" && make install && \
    ldconfig && \
    rm -rf /tmp/Livox-SDK2

# -----------------------------------------------------------------------------
# 3. Python: controller / IK stack (Pink differential IK + QP backends, viz).
#    numpy<2 is forced first so transitive C-extension installs bind to the
#    numpy 1.x ABI matching apt scipy 1.8 / pinocchio.
#    `--ignore-installed blinker` works around apt's old python3-blinker that
#    pip cannot cleanly uninstall.
# -----------------------------------------------------------------------------
RUN pip install --no-cache-dir --ignore-installed blinker \
        "numpy<2" \
        "scikit-learn>=1.4" \
        pin-pink \
        qpsolvers \
        quadprog \
        proxsuite \
        meshcat \
        meshcat-shapes \
        pyquaternion \
        tqdm \
        open3d

# -----------------------------------------------------------------------------
# 4. Python: vision_pipeline ML stack.
#    All versions exact-pinned for reproducibility; CLIP is fetched at a SHA
#    because it is not on PyPI. Model weights ship under
#    vision_pipeline/core/ModelWeights and are bind-mounted via core_ws.
# -----------------------------------------------------------------------------
RUN pip install --no-cache-dir \
        "transformers==4.47.1" \
        "google-genai==1.30.0" \
        "matplotlib==3.9.3" \
        "Pillow==11.0.0" \
        "timm==1.0.17" \
        "ftfy==6.1.1" \
        "regex==2024.11.6" \
        "huggingface_hub==0.27.0" \
        "einops==0.8.0" \
        "pycocotools==2.0.8" \
        "ultralytics==8.3.52"

RUN pip install --no-cache-dir \
        "opencv-python-headless==4.10.0.84" \
        "iopath==0.1.10"

RUN git clone https://github.com/openai/CLIP.git /opt/clip \
    && cd /opt/clip && git checkout a1d071733d7111c9c014f024669f959182114e33
RUN pip install --no-cache-dir --no-deps /opt/clip

# -----------------------------------------------------------------------------
# 5. SAM3 — vendored from git.
#    SAM3's setup.py produces UNKNOWN-0.0.0; bypass with PYTHONPATH instead.
#    (hydra-core kept: used for model config resolution.)
# -----------------------------------------------------------------------------
RUN pip install --no-cache-dir "hydra-core>=1.3.2"

RUN git clone --depth 1 https://github.com/facebookresearch/sam3.git /opt/sam3
ENV PYTHONPATH=/opt/sam3:${PYTHONPATH}

# -----------------------------------------------------------------------------
# 6. API_KEYS stub for vision_pipeline/BBBackBones.py — module-level import is
#    unconditional even when the Gemini backbone is unused. Override at
#    runtime via `-e GEMINI_KEY=...` or a bind mount.
# -----------------------------------------------------------------------------
RUN echo 'import os; GEMINI_KEY = os.environ.get("GEMINI_KEY", "")' \
        > /usr/local/lib/python3.10/dist-packages/API_KEYS.py

# -----------------------------------------------------------------------------
# 7. Final version clamp — restore numpy<2, setuptools 59.6, wheel<0.44 after
#    earlier pip steps inevitably bumped them.
#
#    numpy>=2:       breaks pinocchio + apt scipy 1.8 ABI.
#    setuptools>=70: colcon's python_setup_py literal_eval chokes on the
#                    SpecifierSet object setuptools 69+ returns instead of a
#                    string, so ament_python builds fail at runtime.
#    wheel>=0.44:    its bdist_wheel entry point references
#                    setuptools.command.bdist_wheel, which is a stub-only
#                    module in setuptools 70.x and breaks pkg_resources.
#
#    The rm -rf is required because base-image `uv pip` and this file's `pip`
#    upgrades layered multiple setuptools versions and left stale .dist-info
#    directories behind. importlib.metadata enumerates all of them, so even a
#    fresh install cannot fix the broken entry point without first removing
#    the ghosts. --no-deps prevents pip's resolver from substituting these
#    explicit pins.
#
#    pkg_resources / _distutils_hack must also be wiped: setuptools 70+ split
#    pkg_resources into a sibling top-level package whose __init__.py imports
#    `jaraco.text`. Without --no-deps installing jaraco, leaving the 70+
#    pkg_resources in place causes ModuleNotFoundError at colcon build time.
# -----------------------------------------------------------------------------
RUN rm -rf /usr/local/lib/python3.10/dist-packages/setuptools \
           /usr/local/lib/python3.10/dist-packages/setuptools-*.dist-info \
           /usr/local/lib/python3.10/dist-packages/pkg_resources \
           /usr/local/lib/python3.10/dist-packages/pkg_resources-*.dist-info \
           /usr/local/lib/python3.10/dist-packages/_distutils_hack \
           /usr/local/lib/python3.10/dist-packages/wheel \
           /usr/local/lib/python3.10/dist-packages/wheel-*.dist-info \
    && pip install --no-cache-dir --no-deps "numpy<2" "setuptools==59.6.0" "wheel<0.44"

# -----------------------------------------------------------------------------
# 8. Workspace integration. Base already sources /opt/ros/humble in bashrc;
#    overlay core_ws/install if it exists (it does not until launch_ros.sh
#    runs colcon build at first launch).
# -----------------------------------------------------------------------------
RUN echo '[ -f /home/code/core_ws/install/setup.bash ] && source /home/code/core_ws/install/setup.bash' >> /root/.bashrc

# -----------------------------------------------------------------------------
# 9. Drop setuptools-70+ leftover .pth file. The step-7 clamp removed
#    _distutils_hack/, but distutils-precedence.pth remained because pip saw
#    apt's setuptools 59.6.0 already satisfied the pin and didn't reinstall —
#    so the .pth from the earlier setuptools 82 install was never overwritten.
#    Result: every Python invocation prints
#    `ModuleNotFoundError: No module named '_distutils_hack'` from site.py
#    before falling through. Apt's 59.6.0 doesn't need the precedence hack,
#    so deleting the .pth silences the warning. Placed last so re-running this
#    fix does not invalidate any heavy layers above.
# -----------------------------------------------------------------------------
RUN rm -f /usr/local/lib/python3.10/dist-packages/distutils-precedence.pth

WORKDIR /home/code/core_ws

CMD ["/home/code/h12_sim_scripts/launch_ros.sh"]

# -----------------------------------------------------------------------------
# Tkinter — needed by h1_bringup's slider_debugger (Tk GUI for live wrist /
# gripper control). Appended at the end so iterating on this layer does not
# bust the heavy apt / pip / SAM / robocasa layers above.
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        python3-tk \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# Nav2 + SLAM + rqt + dev/debug ROS packages used by h1_navigation.launch.py
# and day-to-day H1 debugging. Appended at the end (same reasoning as the
# python3-tk block above) so iterating on this list does not bust the heavy
# apt / pip / SAM layers earlier in the file.
#
# ros-humble-navigation2 is the Nav2 metapackage and pulls in
# nav2_bt_navigator, nav2_planner, nav2_controller, nav2_behaviors,
# nav2_lifecycle_manager, nav2_costmap_2d, nav2_smac_planner, etc.
# -----------------------------------------------------------------------------
RUN apt-get update && apt-get install -y --no-install-recommends \
        # Navigation stack
        ros-humble-navigation2 \
        ros-humble-nav2-bringup \
        # SLAM
        ros-humble-slam-toolbox \
        # Lidar 3D -> 2D bridge for Nav2 costmaps
        ros-humble-pointcloud-to-laserscan \
        # rqt debugging GUIs (graph, tf tree, dynamic reconfigure, common plugins)
        ros-humble-rqt \
        ros-humble-rqt-common-plugins \
        ros-humble-rqt-graph \
        ros-humble-rqt-tf-tree \
        ros-humble-rqt-reconfigure \
        # Teleop — drive /cmd_vel by hand to exercise walking_node and Nav2
        ros-humble-teleop-twist-keyboard \
        ros-humble-teleop-twist-joy \
        # Bag recording / replay (lidar + IMU traces for offline FAST-LIO tuning)
        ros-humble-rosbag2 \
        ros-humble-rosbag2-storage-default-plugins \
        # Diagnostics + modern web visualization
        ros-humble-diagnostic-updater \
        ros-humble-foxglove-bridge \
    && rm -rf /var/lib/apt/lists/*

# -----------------------------------------------------------------------------
# GraspGenX (NVlabs) — installed IN-PLACE into system Python (no uv / no venv).
#
# Strategy: install the package --no-deps (prebuilt wheel), then install its deps
# under a FULL pip-freeze constraint so additive deps can only ADD packages,
# never change an installed one (torch 2.12.1+cu130, torchvision, timm,
# transformers, numpy, Pillow, setuptools ...).
#
# The diffusion model IS enabled in-place: diffusers==0.11.1 needs
# huggingface-hub<0.26 (it imports the removed `cached_download`), so we downgrade
# huggingface-hub 0.27.0 -> 0.25.2 — the one version that ALSO satisfies
# transformers 4.47.1. Validated that the vision stack
# (SAM3/CLIP/timm/ultralytics/open3d) still imports under 0.25.2 and that
# graspgenx.grasp_server.GraspGenXSampler imports. Only huggingface-hub moves;
# everything else stays pinned.
#
# Still NOT installed (not needed for grasp inference): pyrender/PyOpenGL,
# scene-synthesizer (rendering/viz), urdfpy (yourdfpy is used instead). viser IS
# installed below for graspgen_server's live grasp visualizer. Running an
# actual grasp additionally needs the checkpoints + gripper_descriptions assets
# (staged dirs below; see .claude/plans). Appended last so iterating here can't
# bust the heavy layers above.
# -----------------------------------------------------------------------------
ENV GRASPGENX_CHECKPOINT_DIR=/opt/graspgenx/ext/graspgenx_checkpoints \
    GRASPGENX_GRIPPER_CFG_DIR=/opt/graspgenx/ext/gripper_descriptions

# Clone source + install the package (importable) without pulling its deps.
# GraspGenX uses PEP 621 [project] metadata, but the system setuptools is clamped
# to 59.6.0 (RosDockerfile:180-187, required for colcon) which predates PEP 621 —
# and pip 22.0.2 build isolation lets that old setuptools win, producing a bogus
# "UNKNOWN-0.0.0" wheel. So we stage a modern setuptools to /tmp/bsetup, build the
# wheel against it (PYTHONPATH + --no-build-isolation), then install the prebuilt
# wheel with the system pip: the build sees PEP 621, but the system's
# colcon-critical setuptools 59.6.0 is never touched. Source stays at /opt/graspgenx.
RUN git clone --depth 1 https://github.com/NVlabs/GraspGenX.git /opt/graspgenx \
    && pip install --no-cache-dir --target=/tmp/bsetup "setuptools>=64,<78" wheel setuptools-scm \
    && SETUPTOOLS_SCM_PRETEND_VERSION=1.0.0 PYTHONPATH=/tmp/bsetup \
         pip wheel --no-deps --no-build-isolation -w /tmp/gwheel /opt/graspgenx \
    && pip install --no-cache-dir --no-deps /tmp/gwheel/graspgenx-*.whl \
    && rm -rf /tmp/bsetup /tmp/gwheel

# Remove a broken Pillow dist-info ghost (pillow-12.2.0.dist-info holds only a
# REQUESTED file, no METADATA) left in an upstream layer; it crashes pip's
# metadata scan the moment a Pillow-dependent dep is touched. The real, intact
# Pillow 11.0.0 install is untouched.
RUN rm -rf /usr/local/lib/python3.10/dist-packages/pillow-12.2.0.dist-info

# Freeze the ENTIRE current environment as the additive-install constraints (see
# header). grep '==' drops editable / file-url / comment lines pip freeze emits.
RUN pip freeze 2>/dev/null | grep '==' > /opt/graspgenx-constraints.txt

# Additive GraspGenX deps that install cleanly under the full freeze (validated
# in a throwaway container: exit 0, every pinned package unchanged).
RUN PIP_CONSTRAINT=/opt/graspgenx-constraints.txt pip install --no-cache-dir \
        "trimesh==4.5.3" \
        "yourdfpy==0.0.56" \
        torch-geometric \
        tensordict \
        webdataset \
        sharedarray \
        python-fcl \
        addict \
        "yapf==0.40.1" \
        tensorboardx \
        h5py \
        imageio

# Enable the diffusion model IN-PLACE: diffusers 0.11.1 needs huggingface-hub<0.26
# (it imports the removed `cached_download`), so downgrade huggingface-hub
# 0.27.0 -> 0.25.2 — the one version that also satisfies transformers 4.47.1.
# Validated: SAM3/CLIP/timm/ultralytics/open3d still import under 0.25.2 and
# graspgenx.grasp_server.GraspGenXSampler imports. Constraint = the full freeze
# MINUS huggingface-hub, so ONLY hf-hub moves; torch/torchvision/timm/transformers/
# numpy/Pillow/setuptools stay pinned.
RUN grep -viE '^huggingface[-_]hub==' /opt/graspgenx-constraints.txt \
        > /opt/graspgenx-constraints-nohf.txt \
    && PIP_CONSTRAINT=/opt/graspgenx-constraints-nohf.txt pip install --no-cache-dir \
        "huggingface-hub==0.25.2" \
        "diffusers==0.11.1"

# viser — web 3D visualizer for graspgen_server's live grasp view
# (http://localhost:8080: scene + object clouds + ranked grasps). Viz-only.
# PINNED to 0.2.23: it's the newest viser compatible with the frozen rich==15.0.0
# (every viser >=0.3 caps rich<15.0.0) and it exposes the modern server.scene API
# (add_point_cloud / add_line_segments / add_mesh_simple) that graspgenx's
# viser_utils requires. Leaving it unpinned is a TRAP — pip 22.0.2 backtracks past
# all the rich-incompatible releases and silently lands on the ancient 0.0.11,
# which has no .scene API and breaks the visualizer at runtime.
# 0.2.23's one conflict with the freeze is psutil (it needs >=5.9.5; the freeze
# pins 5.9.0), so — like the hf-hub block above — install under the freeze MINUS
# psutil and bump psutil by a minimal patch. Everything else (torch/torchvision/
# numpy/Pillow/setuptools/trimesh) stays pinned; viser's remaining deps (msgspec,
# tyro, plyfile, ...) are purely additive.
RUN grep -viE '^psutil==' /opt/graspgenx-constraints.txt \
        > /opt/graspgenx-constraints-viser.txt \
    && PIP_CONSTRAINT=/opt/graspgenx-constraints-viser.txt pip install --no-cache-dir \
        "viser==0.2.23" "psutil==5.9.8"

# Asset staging is deferred to integration (install-only scope). We just create
# the empty target dirs that GRASPGENX_*_DIR point at; populate them later.
# NOTE: pre-baking is currently blocked upstream anyway — the third-party
# gripper_descriptions repo has exhausted its GitHub LFS budget ("This repository
# exceeded its LFS budget"), so its mesh assets cannot be pulled from that source
# right now. The HF checkpoint repo (adithyamurali/GraspGenXModel, ~1.7 GB) IS
# fetchable but is intentionally not baked here, to keep the image lean.
RUN mkdir -p "$GRASPGENX_CHECKPOINT_DIR" "$GRASPGENX_GRIPPER_CFG_DIR"
