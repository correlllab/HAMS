# ==============================
# ROS 2 Humble (apt-based) workspace image
# ==============================
# Deliberately does NOT derive from humanoid_sim_base: robostack-conda's
# libstdc++ ABI mismatched the system gcc when building core_ws. apt ROS 2
# uses the same toolchain the packages were compiled against, so colcon
# builds of FAST_LIO / livox_ros_driver2 link cleanly.
#
# Cross-container DDS: this image uses apt ros-humble-rmw-cyclonedds-cpp;
# the other containers use /cyclonedds from base. Both speak the CycloneDDS
# wire protocol on ROS_DOMAIN_ID=1, so they interop without sharing binaries.
FROM nvidia/cuda:12.2.0-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=America/Denver
ENV LANG=C.UTF-8
ENV ROS_DISTRO=humble
ENV ROS_DOMAIN_ID=1
ENV RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

ARG http_proxy
ARG https_proxy
ENV http_proxy=${http_proxy}
ENV https_proxy=${https_proxy}

# ROS 2 Humble apt repo + base tooling.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ca-certificates curl gnupg locales software-properties-common \
    && locale-gen en_US en_US.UTF-8 && update-locale LC_ALL=C.UTF-8 LANG=C.UTF-8 \
    && add-apt-repository universe \
    && curl -sSL https://raw.githubusercontent.com/ros/rosdistro/master/ros.key \
           -o /usr/share/keyrings/ros-archive-keyring.gpg \
    && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/ros-archive-keyring.gpg] http://packages.ros.org/ros2/ubuntu jammy main" \
           > /etc/apt/sources.list.d/ros2.list \
    && rm -rf /var/lib/apt/lists/*

# Build + ROS 2 packages core_ws needs.
# Livox-SDK2 is built from source below; everything else is apt.
RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential cmake git git-lfs pkg-config \
        python3-pip python3-colcon-common-extensions python3-rosdep \
        python3-vcstool python3-numpy python3-scipy python3-yaml \
        python3-transforms3d \
        libpcl-dev libeigen3-dev libyaml-cpp-dev libopencv-dev \
        ros-humble-ros-base \
        ros-humble-ament-cmake \
        ros-humble-ament-cmake-auto \
        ros-humble-ament-cmake-python \
        ros-humble-ament-lint-auto \
        ros-humble-rosidl-default-generators \
        ros-humble-cv-bridge \
        ros-humble-image-transport \
        ros-humble-vision-msgs \
        ros-humble-xacro \
        ros-humble-robot-state-publisher \
        ros-humble-joint-state-publisher \
        ros-humble-launch-ros \
        ros-humble-launch-xml \
        ros-humble-pcl-ros \
        ros-humble-pcl-conversions \
        ros-humble-tf2-eigen \
        ros-humble-nav-msgs \
        ros-humble-std-msgs \
        ros-humble-std-srvs \
        ros-humble-visualization-msgs \
        ros-humble-rclcpp \
        ros-humble-rclcpp-components \
        ros-humble-rmw-cyclonedds-cpp \
        ros-humble-rviz2 \
        ros-humble-tf2-tools \
        ros-humble-pinocchio \
    && rm -rf /var/lib/apt/lists/*

# Python deps for h12_ros2_controller (Pink differential IK + QP solvers) and
# vision_pipeline (open3d). numpy<2 pin is required because system scipy 1.8
# was built against numpy 1.x ABI and crashes on import under numpy 2.
# Note: do NOT upgrade pip/setuptools here. Ubuntu 22.04 ships setuptools 59.6
# which returns python_requires as a string in setup.py --dry-run output.
# Newer setuptools (69+) returns SpecifierSet(...) which chokes colcon's
# python_setup_py literal_eval and fails the core_ws build.
RUN pip install --no-cache-dir --ignore-installed blinker \
        "numpy<2" \
        "scikit-learn>=1.4" \
        pin-pink \
        qpsolvers \
        quadprog \
        proxsuite \
        meshcat \
        meshcat-shapes \
        pyquaternion \
        tqdm \
        open3d \
    && pip install --no-cache-dir --force-reinstall "setuptools==59.6.0"

# unitree_sdk2_python — see BaseDockerfile for the site-packages copy
# rationale (upstream setup.py drops sub-packages like `b2`).
RUN git clone --depth 1 https://github.com/unitreerobotics/unitree_sdk2_python /tmp/unitree_sdk2_python && \
    pip install /tmp/unitree_sdk2_python && \
    SP=$(python3 -c "import site; print(site.getsitepackages()[0])") && \
    cp -r /tmp/unitree_sdk2_python/unitree_sdk2py/* "$SP/unitree_sdk2py/" && \
    rm -rf /tmp/unitree_sdk2_python && \
    pip install --no-cache-dir --force-reinstall "numpy<2"

# vision_pipeline ML stack. PyTorch with CUDA 13.0 for sm_120 (Blackwell) support.
# Model weights are already checked in under vision_pipeline/core/ModelWeights.
RUN pip install --no-cache-dir \
        torch torchvision --index-url https://download.pytorch.org/whl/cu130 \
    && pip install --no-cache-dir \
        "transformers==4.47.1" \
        "google-genai==1.1.0" \
        "opencv-python==4.10.0.84" \
        "matplotlib==3.9.3" \
        "Pillow==11.0.0" \
        "timm==1.0.17" \
        "ftfy==6.1.1" \
        "regex==2024.11.6" \
        "iopath==0.1.10" \
        "huggingface_hub==0.27.0" \
        "einops==0.8.0" \
        "pycocotools==2.0.8" \
        "ultralytics==8.3.52" \
    && pip install --no-cache-dir git+https://github.com/openai/CLIP.git@a1d0717

# SAM2 — installed editable from GitHub (config YAMLs only resolve via package path).
# Pinned to a known-good commit for reproducibility.
RUN git clone https://github.com/facebookresearch/sam2.git /opt/sam2 && \
    cd /opt/sam2 && git checkout c2ec8e14 && pip install --no-cache-dir -e .

# SAM3 — upstream setup.py produces an UNKNOWN-0.0.0 wheel; vendor via PYTHONPATH.
# Pinned to a known-good commit for reproducibility.
RUN git clone --depth 1 https://github.com/facebookresearch/sam3.git /opt/sam3
ENV PYTHONPATH=/opt/sam3:${PYTHONPATH}

# BBBackBones.py unconditionally imports API_KEYS even when Gemini backbone is
# unused. Provide an empty stub so the yoloworld/owlv2 paths can import.
# Override the key by bind-mounting or exporting GEMINI_KEY=... as needed.
RUN echo 'import os; GEMINI_KEY = os.environ.get("GEMINI_KEY", "")' \
        > /usr/local/lib/python3.10/dist-packages/API_KEYS.py

# Repin numpy<2 / setuptools==59.6 — torch and the ML stack above silently pull
# in newer versions that break pinocchio's numpy ABI and colcon's setup.py
# literal_eval for ament_python packages.
RUN pip install --no-cache-dir --force-reinstall "numpy<2" "setuptools==59.6.0"

# Livox-SDK2 — required by livox_ros_driver2.
RUN git clone --depth 1 https://github.com/Livox-SDK/Livox-SDK2.git /tmp/Livox-SDK2 && \
    cd /tmp/Livox-SDK2 && mkdir build && cd build && \
    cmake .. -DCMAKE_POLICY_VERSION_MINIMUM=3.5 && make -j"$(nproc)" && make install && \
    ldconfig && \
    rm -rf /tmp/Livox-SDK2

RUN echo 'source /opt/ros/humble/setup.bash' >> /root/.bashrc && \
    echo '[ -f /home/code/core_ws/install/setup.bash ] && source /home/code/core_ws/install/setup.bash' >> /root/.bashrc

WORKDIR /home/code/core_ws

CMD ["/home/code/h12_sim_scripts/launch_ros.sh"]
